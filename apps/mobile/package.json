{
  "name": "@easy-meditation/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "prestart": "npm --prefix ../../packages/shared run build",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "pretypecheck": "npm --prefix ../../packages/shared run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm --prefix ../../packages/shared run build",
    "pretest:unit": "npm --prefix ../../packages/shared run build",
    "test:unit": "vitest run",
    "pretest:native": "npm --prefix ../../packages/shared run build",
    "test:native": "jest --runInBand",
    "test": "npm run test:unit && npm run test:native"
  },
  "dependencies": {
    "@easy-meditation/shared": "file:../../packages/shared",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@shopify/react-native-skia": "v2.0.0-next.4",
    "@tanstack/react-query": "^5.81.5",
    "expo": "~53.0.27",
    "expo-audio": "~0.4.9",
    "expo-constants": "~17.1.8",
    "expo-crypto": "~14.1.5",
    "expo-font": "~13.3.2",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.4",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "zod": "^3.25.76",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.14",
    "babel-preset-expo": "^13.2.3",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.14",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "^19.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
