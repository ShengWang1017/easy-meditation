{
  "name": "@easy-meditation/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm --prefix ../../packages/shared run build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "npm --prefix ../../packages/shared run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "predev": "npm --prefix ../../packages/shared run build",
    "dev": "tsx watch src/server.ts",
    "prestart": "npm --prefix ../../packages/shared run build",
    "start": "node dist/src/server.js",
    "pretest": "npm --prefix ../../packages/shared run build",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@easy-meditation/shared": "file:../../packages/shared",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.1.0",
    "@prisma/client": "^6.11.1",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.12",
    "prisma": "^6.11.1",
    "tsx": "^4.20.3",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
